{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production",
    "VITE_APP_ID": "quickcash-app",
    "VITE_OAUTH_PORTAL_URL": "https://quickcash-app.vercel.app",
    "VITE_API_URL": "https://quickcash-app.vercel.app"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
